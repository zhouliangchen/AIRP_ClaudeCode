# Python bytecode cache
__pycache__/
*.pyc

# Runtime-generated files (auto-rebuilt by handler.py)
skills/styles/content.js
skills/styles/state.js

# User input buffer (runtime only)
skills/styles/input.txt

# Card path config (runtime routing)
skills/styles/.card_path

# Temporary response file
skills/styles/response.txt

# Pending signal file
skills/styles/.pending

# Session init signal (runtime touch)
skills/styles/.session_init

# Runtime context files
skills/styles/round_context.txt
skills/styles/import_context.txt

# Card-specific openings (runtime, changes per card import)
skills/styles/openings.json

# Lock files
*.lock
.claude/scheduled_tasks.lock

# Image generation API local secrets (never commit)
image_config.local.json
skills/image_config.local.json
.image_api.json
*.secret.json

# User card folders — ignore all top-level dirs except project core
# (Any new card folder is automatically protected from accidental git add)
*/
!.claude/
!.claude/commands/
!.claude/commands/**
!.claude/skills/
!.claude/skills/**
!.claude/settings.local.json
!skills/
